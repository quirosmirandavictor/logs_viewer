<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

	<targets>
		<!-- NLog Target (.NET Standard Format) -->
		<target xsi:type="File" name="logfile" fileName="logs/worker-${shortdate}.log"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

		<!-- Exact simulation of Python's standard logging format -->
		<target xsi:type="File" name="pythonSimulatorFile" fileName="logs/python_format-${shortdate}.log"
				layout="${date:format=yyyy-MM-dd HH\:mm\:ss,fff} - ${logger} - ${level:uppercase=true} - ${message} ${exception:format=tostring}" />

		<!-- Generic Console Target for development tracking -->
		<target xsi:type="Console" name="logconsole"
				layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />
	</targets>

	<rules>
		<!-- OPTIONAL: If you want to see Microsoft framework startup info logs in your console, leave these commented out. -->
		<!-- If your console gets too crowded with background noise, uncomment them to hide framework internals. -->
		<!--
		<rule name="Microsoft.*" maxlevel="Info" final="true" />
		<rule name="System.*" maxlevel="Info" final="true" />
		-->	
		<!-- This guarantees that Trace, Debug, Info, Warn, Error, and Fatal are all captured everywhere -->
		<rule name="*" minlevel="Trace" writeTo="logfile,pythonSimulatorFile,logconsole" />
	</rules>
</nlog>
